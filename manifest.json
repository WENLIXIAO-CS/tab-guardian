{
  "manifest_version": 3,
  "name": "Tab Guardian",
  "version": "3.5.0",
  "description": "Monitor tab usage, detect unused tabs, and free up memory with one click.",
  "permissions": [
    "tabs",
    "alarms",
    "notifications",
    "storage",
    "system.memory",
    "favicon",
    "browsingData",
    "activeTab"
  ],
  "optional_permissions": [
    "scripting"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
